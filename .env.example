# --- skilltool client environment ---
# Copy to `.env` and source it, or export these directly. The CLI reads
# these with precedence: env > ~/.config/skilltool/config.toml > defaults.

# Tailscale IP or DNS name of Server A hosting the registry.
SKILLTOOL_REGISTRY=http://100.x.x.x:8765

# Token required for `skilltool publish`. Must match the server-side
# SKILLTOOL_PUBLISH_TOKEN configured in registry/.env.
SKILLTOOL_TOKEN=your-publish-token
