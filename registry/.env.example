# --- skilltool registry server configuration ---

# Storage root inside the container. docker-compose.yml mounts ./data
# from the host into this path. Usually no reason to change.
SKILLTOOL_STORAGE_DIR=/data

# Path to the users.toml file consulted on every authenticated request.
# Defaults to $SKILLTOOL_STORAGE_DIR/users.toml so it rides the data
# volume; override here if you want to mount it separately.
# SKILLTOOL_USERS_FILE=/data/users.toml

# Append-only publish audit log. Defaults to $SKILLTOOL_STORAGE_DIR/publish.log.
# SKILLTOOL_AUDIT_LOG=/data/publish.log

# Optional: bind only to a specific interface (e.g. Tailscale IP).
# Leave blank to accept on all interfaces.
# SKILLTOOL_BIND=100.x.x.x
